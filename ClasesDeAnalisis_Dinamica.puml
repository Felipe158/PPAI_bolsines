@startuml

autonumber

actor "Encargado de Bolsines" as EB

boundary PantallaRegistrarRecepcionBolsin as Pantalla
control GestorRegistrarRecepcionBolsin as Gestor

entity Sesion
entity Empleado
entity ComisionMedica
entity Bolsin
entity Remito
entity Documento
entity Estado

' ==========================================
' Inicio CU
' ==========================================

EB ->> Pantalla : seleccionarRegistrarRecepcion()

Pantalla -> Gestor : iniciarCU()

activate Gestor

' ==========================================
' Obtener CM del usuario
' ==========================================
Gestor -> Gestor : obtenerUsuario()

Gestor -> Sesion : obtenerUsuario()
Sesion --> Gestor : usuario

Gestor -> Sesion : obtenerEmpleado()
Sesion --> Gestor : empleado

Gestor -> Empleado : getCM()
Empleado --> Gestor : cmUsuario

' ==========================================
' Buscar bolsines enviados
' ==========================================

Gestor -> Bolsin : buscarEnviados(cmUsuario)
Bolsin --> Gestor : listaBolsines

Gestor --> Pantalla : mostrarBolsines(listaBolsines)

' ==========================================
' Selección de bolsín
' ==========================================

EB -> Pantalla : seleccionarBolsin()

Pantalla -> Gestor : tomarSeleccion(bolsin)

Gestor -> Bolsin : obtenerInformacionRemito()
Bolsin --> Gestor : remitos

loop por cada remito
    Gestor -> Remito : obtenerDetalle()
    Remito --> Gestor : detalle

    loop por cada documento
        Gestor -> Documento : getDatosDocumentacion()
        Documento --> Gestor : datosDoc
    end
end

Gestor --> Pantalla : mostrarDetalle()

' ==========================================
' Selección opción recepción
' ==========================================

Pantalla --> EB : solicitarOpcionRecepcion()

EB -> Pantalla : opcionRecepcion()

Pantalla -> Gestor : registrarRecepcion(opcion)

Gestor --> Pantalla : solicitarConfirmacion()

EB -> Pantalla : confirmar()

Pantalla -> Gestor : confirmarOperacion()

' ==========================================
' Actualización de estados
' ==========================================

loop por cada remito
    Gestor -> Remito : setEstado(Recibido y Aceptado)

    loop por cada documento
        Gestor -> Documento : setEstado(Recibida y Aceptada)
    end
end

Gestor -> Bolsin : crearCEBolsin()
Gestor -> Bolsin : setEstado(Recibido en CM destino)

' ==========================================
' Notificación
' ==========================================

Gestor -> ComisionMedica : notificarRecepcion()

Gestor --> Pantalla : informarExito()

deactivate Gestor

@enduml